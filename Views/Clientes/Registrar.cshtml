@model MonitoreoWeb.Models.ViewModels.RegistroClienteViewModel

@{
    ViewData["Title"] = "Registrar cliente";
}

<div class="container mt-4">
    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-4">
            <h2 class="fw-bold mb-1">Registrar cliente</h2>
            <p class="text-muted mb-4">Ingrese los datos del nuevo cliente</p>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            <form asp-action="Registrar" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Nombre" class="form-label fw-semibold"></label>
                        <input asp-for="Nombre" class="form-control" placeholder="Nombre del cliente" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Apellido" class="form-label fw-semibold"></label>
                        <input asp-for="Apellido" class="form-control" placeholder="Apellido del cliente" />
                        <span asp-validation-for="Apellido" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Telefono" class="form-label fw-semibold"></label>
                        <input asp-for="Telefono" class="form-control" placeholder="Teléfono" />
                        <span asp-validation-for="Telefono" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control" placeholder="correo@cliente.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="Activo" class="form-check-input" />
                    <label asp-for="Activo" class="form-check-label"></label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        Guardar cliente
                    </button>
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">
                        Volver
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}