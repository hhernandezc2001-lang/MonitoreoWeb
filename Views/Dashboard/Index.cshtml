@using System.Security.Claims

@{
    ViewData["Title"] = "Dashboard";
}

<h1>Bienvenido al panel interno</h1>

<p>Usuario autenticado: @User.Identity?.Name</p>
<p>Rol: @User.FindFirst(ClaimTypes.Role)?.Value</p>

<div class="mt-4 d-flex gap-2">
    @if (User.IsInRole("Admin"))
    {
        <a asp-controller="Auth" asp-action="Registrar" class="btn btn-primary">
            Registrar nuevo usuario
        </a>
    }

    <a asp-controller="Auth" asp-action="Logout" class="btn btn-danger">
        Cerrar sesión
    </a>
</div>