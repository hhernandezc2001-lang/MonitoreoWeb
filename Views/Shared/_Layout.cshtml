@using System.Security.Claims

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var isAdmin = User.IsInRole("Admin");

    string Active(string controller, string action = "")
    {
        var controllerOk = currentController.Equals(controller, StringComparison.OrdinalIgnoreCase);
        var actionOk = string.IsNullOrEmpty(action) || currentAction.Equals(action, StringComparison.OrdinalIgnoreCase);

        return controllerOk && actionOk ? "active" : "";
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MonitoreoWeb</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    @if (isAuthenticated && isAdmin)
    {
        <div class="admin-layout">

            <!-- Barra lateral -->
            <aside class="admin-sidebar">
                <div class="admin-sidebar-title">
                    MonitoreoWeb
                </div>

                <nav class="admin-menu">

                    <a class="admin-menu-link @Active("Admin", "Inicio")"
                       asp-controller="Admin"
                       asp-action="Inicio">
                        Inicio
                    </a>

                    <a class="admin-menu-link @Active("Dashboard", "Index")"
                       asp-controller="Dashboard"
                       asp-action="Index">
                        Dashboards
                    </a>

                    <a class="admin-menu-link @Active("Admin", "DispositivosReparacion")"
                       asp-controller="Admin"
                       asp-action="DispositivosReparacion">
                        Dispositivos en reparación
                    </a>

                    <a class="admin-menu-link @Active("Admin", "Tecnicos")"
                       asp-controller="Admin"
                       asp-action="Tecnicos">
                        Técnicos dados de alta
                    </a>

                    <a class="admin-menu-link @Active("Admin", "RegistrarUsuario")"
                       asp-controller="Admin"
                       asp-action="RegistrarUsuario">
                        Registrar nuevos usuarios
                    </a>

                    <a class="admin-menu-link @Active("Clientes", "Registrar")"
                       asp-controller="Clientes"
                       asp-action="Registrar">
                        Registrar clientes
                    </a>

                    <a class="admin-menu-link @Active("Admin", "GenerarToken")"
                       asp-controller="Admin"
                       asp-action="GenerarToken">
                        Generación de token único
                    </a>

                    <a class="admin-menu-link @Active("Admin", "Activaciones")"
                       asp-controller="Admin"
                       asp-action="Activaciones">
                        Activar/Desactivar Tokens y Técnicos
                    </a>

                </nav>

                <!-- Footer de la barra lateral -->
                <div class="admin-sidebar-footer">
                    <div class="admin-user-name">
                        @User.Identity?.Name
                    </div>

                    <div class="admin-user-role">
                        Rol: @User.FindFirst(ClaimTypes.Role)?.Value
                    </div>

                    <!-- Botón de Cerrar sesión -->
                    <a class="admin-logout"
                       asp-controller="Auth"
                       asp-action="Logout">
                        Cerrar sesión
                    </a>
                </div>
            </aside>

            <!-- Contenido principal -->
            <main class="admin-main">
                <div class="admin-content">
                    @RenderBody()
                </div>
            </main>

        </div>
    }
    else
    {
        <main>
            @RenderBody()
        </main>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>