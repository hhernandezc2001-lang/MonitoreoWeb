@model MonitoreoWeb.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Iniciar sesión";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MonitoreoWeb</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f7f7f7;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .card {
            width: 100%;
            max-width: 400px;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .card-header {
            text-align: center;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .btn-primary {
            width: 100%;
            padding: 12px;
            background-color: #007bff;
            border: none;
            border-radius: 8px;
        }

        .btn-outline-secondary {
            width: 100%;
            padding: 12px;
            border: 2px solid #007bff;
            border-radius: 8px;
            color: #007bff;
        }

            .btn-outline-secondary:hover {
                background-color: #007bff;
                color: white;
            }

        .form-check-label {
            margin-left: 5px;
        }
    </style>
</head>

<body>
    <div class="card">
        <div class="card-header">
            <h2 class="fw-bold">Iniciar sesión</h2>
            <p class="text-muted">Accede a tu cuenta</p>
        </div>
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">Correo electrónico</label>
                <input asp-for="Email" class="form-control form-control-lg" placeholder="Ingresa tu correo" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Contraseña</label>
                <input asp-for="Password" class="form-control form-control-lg" type="password" placeholder="Ingresa tu contraseña" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="Recordarme" class="form-check-input" type="checkbox" />
                <label class="form-check-label">Recordarme</label>
            </div>

            <button type="submit" class="btn btn-primary">Iniciar sesión</button>
            <a asp-action="Registrar" class="btn btn-outline-secondary mt-3">¿No tienes cuenta? Regístrate</a>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>